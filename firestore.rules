rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Match the users collection and user document
    match /users/{userId} {
      // Allow the user to read and write their own document
      allow read, write: if request.auth != null && request.auth.uid == userId;

      // Match the scans subcollection
      match /scans/{scanId} {
        // Allow the user to read and write their own scans
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }
  }
}
